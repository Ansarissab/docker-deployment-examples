#!/bin/bash

# Check for arguments
if [ "$#" -ne 2 ]; then
    echo "Usage: gen-cert <domain> <ip>"
    echo "Example: gen-cert wordpress.local 172.16.189.131"
    exit 1
fi

DOMAIN=$1
IP=$2
CERT_DIR="$HOME/docker/certs"
KEY_FILE="$CERT_DIR/$DOMAIN.key"
CRT_FILE="$CERT_DIR/$DOMAIN.crt"

# Create directory if it doesn't exist
mkdir -p "$CERT_DIR"

echo "--- Generating Certificate for $DOMAIN ($IP) ---"

# Generate the certificate with SAN (Subject Alternative Name)
openssl req -x509 -nodes -days 825 -newkey rsa:2048 \
  -keyout "$KEY_FILE" \
  -out "$CRT_FILE" \
  -subj "/CN=$DOMAIN" \
  -addext "subjectAltName=DNS:$DOMAIN,IP:$IP"

if [ $? -eq 0 ]; then
    echo "✅ Certificate generated at $CRT_FILE"
else
    echo "❌ Failed to generate certificate."
    exit 1
fi

echo "--- Adding to macOS System Keychain (Password Required) ---"

# Add and trust the certificate
sudo security add-trusted-cert -d -r trustRoot \
  -k /Library/Keychains/System.keychain \
  "$CRT_FILE"

if [ $? -eq 0 ]; then
    echo "✅ $DOMAIN is now trusted on this Mac."
    echo "Next: Upload the .key and .crt files to Nginx Proxy Manager."
else
    echo "❌ Failed to add certificate to Keychain."
    exit 1
fi
